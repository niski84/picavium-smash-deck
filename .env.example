# PiKVM Smash Deck — configuration
# Copy to .env and fill in your values.

# PiKVM device
PIKVM_HOST=192.168.1.x          # hostname or IP (https:// added automatically)
PIKVM_USER=admin                # PiKVM web UI username
PIKVM_PASS=admin                # PiKVM web UI password (append TOTP code if 2FA enabled)

# SSH — required for diagnostics, go2rtc install, EDID fix, upgrade, bitrate tuning
PIKVM_SSH_USER=root
PIKVM_SSH_PASS=                 # leave blank to use key auth only
PIKVM_SSH_KEY=                  # path to SSH private key (optional)

# Server
PORT=8095
